# Server
PORT=5000

# MongoDB
ATLAS_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Admin (used for login sync)
INITIAL_ADMIN_EMAIL=admin@spireeta.com
INITIAL_ADMIN_PASSWORD=your_password

# Super admin notification email (enquiries)
SUPERADMIN_EMAIL=admin@spireeta.com

# SMTP (optional – leave unset to skip sending emails; enquiries still save)
# If SMTP_HOST is not set, email is skipped and no error is thrown.
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=hr@yourdomain.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Spireeta HR" <hr@yourdomain.com>
# SMTP_TLS_REJECT_UNAUTHORIZED=false
